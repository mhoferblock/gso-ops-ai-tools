# GSO Ops AI Tools — Environment Variables
# Copy to .env for local development.  On Databricks, set via App config or secret scope.

# ── AI (optional but recommended) ────────────────────────────────────────────
# Enables Claude-powered tool summarization and the AOL AI chat assistant.
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Security (required in production) ────────────────────────────────────────
# Change this to a strong random value in production.
# Generate one:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Database (required in production on Databricks) ───────────────────────────
# Path to the SQLite database file.
# Local dev:    leave blank (defaults to ./data/gso_tools.db)
# Databricks:   set to a Unity Catalog Volume path, e.g.:
#               /Volumes/main/gso_ops/app_data/gso_tools.db
DB_PATH=

# ── Databricks (auto-detected, no manual config needed in most cases) ─────────
# These are auto-set by the Databricks Apps runtime.
# You should NOT set these manually.
# DATABRICKS_APP_NAME=
# DATABRICKS_RUNTIME_VERSION=
# DATABRICKS_HOST=
